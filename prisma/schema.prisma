generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String   @id
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  Post      Post[]
}

model Post {
  id                String     @id
  title             String
  slug              String     @unique
  excerpt           String
  content           String
  featuredImage     String?
  status            PostStatus @default(DRAFT)
  categoryId        String
  metaTitle         String
  metaDesc          String
  schemaJson        String?
  wordCount         Int        @default(0)
  readingTime       Int        @default(0)
  viewCount         Int        @default(0)
  featured          Boolean    @default(false)
  seoScore          Int?
  publishedAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime
  pinterestImage    String?
  pinterestPinId    String?
  pinterestPinUrl   String?
  pinterestPinnedAt DateTime?
  Category          Category   @relation(fields: [categoryId], references: [id])
  Tag               Tag[]

  @@index([slug])
  @@index([status, publishedAt])
}

model Subscriber {
  id        String   @id
  name      String
  email     String   @unique
  active    Boolean  @default(true)
  source    String   @default("website")
  createdAt DateTime @default(now())
}

model Tag {
  id   String @id
  name String @unique
  slug String @unique
  Post Post[]
}

model TopicQueue {
  id              String      @id
  keyword         String
  category        String
  priority        Int         @default(0)
  status          QueueStatus @default(PENDING)
  source          String?     @default("manual")
  originalQuery   String?
  estimatedCPC    String?
  monthlySearches String?
  failReason      String?
  createdAt       DateTime    @default(now())
  processedAt     DateTime?
}

enum PostStatus {
  DRAFT
  REVIEW
  PUBLISHED
  REJECTED
}

enum QueueStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}
