# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@your-rds-endpoint:5432/aiblog"

# ─── AWS ──────────────────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_BEDROCK_MODEL_ID="anthropic.claude-sonnet-4-5"
AWS_S3_BUCKET="your-blog-images-bucket"

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
NEXT_PUBLIC_SITE_NAME="My AI Blog"
NEXT_PUBLIC_ADSENSE_ID="ca-pub-XXXXXXXXXXXXXXXX"

# ─── Security ─────────────────────────────────────────────────
WEBHOOK_SECRET="change-this-to-a-random-secret"
ADMIN_API_KEY="change-this-to-a-random-key"

# ─── CloudFront (output from CDK deploy) ──────────────────────
CLOUDFRONT_DOMAIN="xxxxx.cloudfront.net"
