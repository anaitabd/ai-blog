# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@your-rds-endpoint:5432/aiblog"

# ─── AWS ──────────────────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_BEDROCK_MODEL_ID="anthropic.claude-sonnet-4-5"
AWS_S3_BUCKET="your-blog-images-bucket"

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
NEXT_PUBLIC_SITE_NAME="My AI Blog"
NEXT_PUBLIC_ADSENSE_ID="ca-pub-XXXXXXXXXXXXXXXX"

# ─── Security ─────────────────────────────────────────────────
WEBHOOK_SECRET="change-this-to-a-random-secret"
ADMIN_API_KEY="change-this-to-a-random-key"
# Shared secret for Lambda → Next.js internal API calls (youtube publisher, email notifier)
INTERNAL_SECRET="change-this-to-another-random-secret"

# ─── CloudFront (output from CDK deploy) ──────────────────────
CLOUDFRONT_DOMAIN="xxxxx.cloudfront.net"

# ─── AWS SES ──────────────────────────────────────────────────
# Verified SES sender identity — must match /wealthbeginners/ses/from-email in SSM
SES_FROM_EMAIL="hello@wealthbeginners.com"
# TODO: Request SES production access at console.aws.amazon.com/ses before sending to real subscribers

# ─── YouTube OAuth2 (store as SecureString in SSM — do NOT put real values here) ─
# SSM paths: /wealthbeginners/youtube/client-id
#            /wealthbeginners/youtube/client-secret
#            /wealthbeginners/youtube/refresh-token
# Admin contact email: /wealthbeginners/admin-email  (SecureString in SSM)


# ── Email: Resend (primary — replaces SES sandbox) ───────────────────────────
# Get free API key at https://resend.com (takes 2 minutes, 100 emails/day free)
# 1. Sign up at resend.com
# 2. Go to API Keys → Create API Key
# 3. Paste it here AND add to Amplify Console env vars
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
